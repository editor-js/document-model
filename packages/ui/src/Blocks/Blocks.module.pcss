.ejs-blocks {
  outline: none;
  display: grid;
  grid-template-columns: 1fr;
}

.ejs-block {
  position: relative;
  width: 100%;

  &__contents {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
  }
}

/**
 * Zero-width space wrapper that will prevent Safari from deleting blocks if there is no content in host
 */
.ejs__host-holder {
  line-height: 0;
  width: 0;
  height: 0;
  user-select: none;
}
