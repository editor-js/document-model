.inline-toolbar {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 3;

  /* @todo move internal tools to a separate package and move this styles to link tool? */
  &__input {
    background: #F8F8F8;
    border: 1px solid rgba(226,226,229,0.20);
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 14px;
    line-height: 22px;


    outline: none;
    margin: 0;
    width: 100%;
    box-sizing: border-box;
    font-weight: 500;
    font-family: inherit;
  }
}
